# 复制为 fnos.env 后，再填写本台 NAS 自己的配置。
# 不要将真实的 fnos.env 分享给其他人。

# 至少 32 位随机字符。每台 NAS 都必须使用不同的值。
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# 首次通过 http://NAS 局域网 IP:3000 测试时为 false。
# 配置域名、反向代理与 HTTPS 后，改为 true 并重新启动容器。
COOKIE_SECURE=false

# 运行身份。NAS 固定为 production；APP_VERSION 应与 QC86_IMAGE 的版本标签一致。
# 例如镜像使用 :v1.0.1 时，这里填写 v1.0.1。
APP_STAGE=production
APP_VERSION=v1.0.0

# 如果服务商信息在后台的“API 对接管理”中填写，可以留空。
QC86_USERNAME=
QC86_PASSWORD=

# 只有使用 docker-compose.ghcr.yml 从 GitHub 自动构建的镜像部署时才填写。
# 正式环境请固定到一个具体版本，不要长期使用 latest。
# 示例：ghcr.io/your-github-account/qc86-platform:v1.0.1
QC86_IMAGE=
