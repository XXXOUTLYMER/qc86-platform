<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>API 对接管理 - 卡密接码平台</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .provider-type{display:inline-flex;padding:3px 8px;border-radius:5px;background:#edf7f1;color:#16784a;font-size:12px;font-weight:600}
    .provider-summary{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-bottom:18px}
    .provider-summary>div{padding:14px;border:1px solid #e7e9ec;border-radius:6px;background:#fff}
    .provider-summary strong{display:block;font-size:22px;margin-top:4px}
    .credential-group{padding:12px;background:#f7f8fa;border:1px solid #e7e9ec;border-radius:6px;margin-bottom:14px}
    .debug-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;align-items:end}
    .uoomsg-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;align-items:end}
    .history-output{max-height:260px;overflow:auto;white-space:pre-wrap;background:#101418;color:#d7f8df;border-radius:6px;padding:12px;font:12px/1.6 ui-monospace,SFMono-Regular,Menlo,monospace}
    .provider-switcher{display:flex;gap:8px;overflow-x:auto;padding:2px 0 10px;margin:0 0 8px;scrollbar-width:thin}
    .provider-switch{flex:0 0 auto;min-width:166px;max-width:230px;padding:12px 14px;text-align:left;border:1px solid #dde3e7;border-radius:7px;background:#fff;color:#263238;cursor:pointer;transition:.18s ease}
    .provider-switch:hover{border-color:#95cbb0;background:#f6fbf8}.provider-switch.is-active{border-color:#21965d;background:#ecf8f1;box-shadow:0 0 0 2px rgba(33,150,93,.1)}
    .provider-switch strong,.provider-switch small{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.provider-switch small{margin-top:4px;color:#708078;font-size:12px}
    .provider-panel{display:none}.provider-panel.is-active{display:block}.provider-hero{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;padding-bottom:16px;border-bottom:1px solid #edf0f1;margin-bottom:16px}.provider-hero h3{margin:0}.provider-hero p{margin:6px 0 0;color:#78827b;font-size:13px}.provider-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
    .provider-projects{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0 16px}.provider-project{padding:7px 10px;border-radius:5px;background:#f5f8f6;border:1px solid #e1e9e4;font-size:12px;color:#3e5145}.provider-project em{font-style:normal;color:#8b9690;margin-left:5px}
    .provider-empty{padding:18px;border:1px dashed #d8e0dc;border-radius:6px;background:#fafcfb;color:#7c8881;font-size:13px}
    @media(max-width:700px){.provider-summary{grid-template-columns:1fr}.provider-summary>div{display:flex;justify-content:space-between;align-items:center}.provider-summary strong{margin:0}}
    @media(max-width:900px){.debug-grid,.uoomsg-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:560px){.debug-grid,.uoomsg-grid{grid-template-columns:1fr}.provider-hero{display:block}.provider-actions{justify-content:flex-start;margin-top:12px}.provider-switch{min-width:150px}}
  </style>
</head>
<body>
  <% const safeUoomsgProviders = typeof uoomsgProviders !== 'undefined' && Array.isArray(uoomsgProviders) ? uoomsgProviders : []; %>
  <%- include('partials/header', { admin, active: 'api-providers' }) %>
  <div class="main">
    <h2>API 对接管理</h2>
    <p style="color:#888;font-size:13px;margin-bottom:16px">不同服务商的账号、Token 和接口地址相互独立。项目绑定后，卡密会自动调用对应 API。</p>

    <% if (success) { %><div class="message message-success"><%= success %></div><% } %>
    <% if (error) { %><div class="message message-error"><%= error %></div><% } %>

    <div class="provider-summary">
      <div><span>服务商总数</span><strong><%= providers.length %></strong></div>
      <div><span>已启用</span><strong><%= providers.filter(function(p){ return p.is_active; }).length %></strong></div>
      <div><span>已绑定项目</span><strong><%= providers.reduce(function(total,p){ return total + Number(p.channel_count || 0); }, 0) %></strong></div>
    </div>

    <div class="action-bar"><button class="btn btn-primary" onclick="openAddModal()">+ 添加 API 服务商</button><a class="btn btn-cancel" href="/admin/channels">管理项目绑定</a></div>

    <% if (!providers.length) { %>
      <div class="card"><div class="card-body"><div class="provider-empty">还没有 API 服务商。请先添加一个平台，再为项目选择对应的平台。</div></div></div>
    <% } else { %>
      <div class="provider-switcher" role="tablist" aria-label="API 平台选择">
        <% providers.forEach(function(p, index) { %>
          <button class="provider-switch <%= index === 0 ? 'is-active' : '' %>" type="button" data-provider-tab="<%= p.id %>" role="tab" aria-selected="<%= index === 0 ? 'true' : 'false' %>">
            <strong><%= p.name %></strong><small><%= p.provider_type %> · <%= p.channel_count || 0 %> 个项目 · <%= p.is_active ? '已启用' : '已停用' %></small>
          </button>
        <% }); %>
      </div>

      <% providers.forEach(function(p, index) { const providerChannels = channels.filter(function(ch){ return Number(ch.provider_id) === Number(p.id); }); %>
        <section class="card provider-panel <%= index === 0 ? 'is-active' : '' %>" data-provider-panel="<%= p.id %>"><div class="card-body">
          <div class="provider-hero">
            <div><h3><%= p.name %> <span class="provider-type"><%= p.provider_type %></span></h3><p><%= p.description || '当前平台的账号配置、绑定项目和调试工具都集中在这里。' %></p></div>
            <div class="provider-actions">
              <button class="btn btn-primary btn-sm" data-provider="<%= encodeURIComponent(JSON.stringify({ id: p.id, name: p.name, provider_type: p.provider_type, base_url: p.base_url, description: p.description, is_active: p.is_active, is_system: p.is_system, strip_sms_metadata: p.strip_sms_metadata })) %>" onclick="openEditModal(this)">编辑平台</button>
              <button class="btn btn-success btn-sm" onclick="testProvider(<%= p.id %>, this)">测试连接</button>
              <% if (!p.is_system) { %><form method="POST" action="/admin/api-providers/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('确定删除这个 API 服务商吗？')"><button class="btn btn-danger btn-sm">删除</button></form><% } %>
            </div>
          </div>

          <h4 style="margin:0 0 8px">绑定项目</h4>
          <% if (providerChannels.length) { %><div class="provider-projects"><% providerChannels.forEach(function(ch) { %><span class="provider-project"><%= ch.name %><em><%= ch.channel_id || ch.api_keyword || '未设置标识' %></em></span><% }); %></div><% } else { %><div class="provider-empty">暂未绑定项目。前往“管理项目绑定”即可把项目关联到 <%= p.name %>。</div><% } %>

          <% if (p.provider_type === 'uoomsg') { %>
            <h3 style="margin:22px 0 4px"><%= p.name %> API 调试工具</h3>
            <p style="font-size:13px;color:#888;margin:4px 0 14px">余额、取号、取码、释放、拉黑、发送短信和历史记录都会使用当前平台配置。取号和发送短信会产生真实 API 操作。</p>
            <div class="uoomsg-grid">
              <div class="form-group"><label>项目</label><select id="uoomsgChannelId-<%= p.id %>"><option value="">-- 选择项目 --</option><% providerChannels.forEach(function(ch) { %><option value="<%= ch.id %>"><%= ch.name %></option><% }); %></select></div>
              <div class="form-group"><label>手机号</label><input id="uoomsgPhone-<%= p.id %>" inputmode="numeric" placeholder="查码/释放/拉黑/发送用"></div>
              <div class="form-group"><label>目标号码（发送短信）</label><input id="uoomsgToPhone-<%= p.id %>" inputmode="numeric" placeholder="例如：1069xxxxxxxx"></div>
              <div class="form-group"><label>项目 ID（发送短信，可选）</label><input id="uoomsgProjId-<%= p.id %>" placeholder="按服务商要求填写"></div>
              <div class="form-group"><label>短信内容（发送短信）</label><input id="uoomsgContent-<%= p.id %>" placeholder="请填写发送内容"></div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
              <button class="btn btn-success" type="button" onclick="uoomsgAction(<%= p.id %>, 'balance')">查询余额</button><button class="btn btn-primary" type="button" onclick="uoomsgAction(<%= p.id %>, 'get-phone')">获取号码</button><button class="btn btn-success" type="button" onclick="uoomsgAction(<%= p.id %>, 'get-code')">查询短信</button><button class="btn btn-danger" type="button" onclick="uoomsgAction(<%= p.id %>, 'blacklist')">拉黑号码</button><button class="btn" type="button" style="background:#f39c12;color:#fff" onclick="uoomsgAction(<%= p.id %>, 'release')">释放号码</button><button class="btn btn-primary" type="button" onclick="uoomsgAction(<%= p.id %>, 'send')">发送短信</button><button class="btn btn-cancel" type="button" onclick="uoomsgAction(<%= p.id %>, 'history')">查询历史（每分钟一次）</button>
            </div>
            <div id="uoomsgResult-<%= p.id %>" style="margin-top:12px;display:none"></div>
          <% } else { %>
            <h3 style="margin:22px 0 4px"><%= p.name %> API 调试工具</h3>
            <p style="font-size:13px;color:#888;margin:4px 0 14px">下面的操作只会调用 <%= p.name %> 已绑定的项目。</p>
            <div class="debug-grid">
              <div class="form-group"><label>项目</label><select id="apiChannelId-<%= p.id %>"><option value="">-- 选择项目 --</option><% providerChannels.forEach(function(ch) { %><option value="<%= ch.id %>" data-channel-id="<%= ch.channel_id || '' %>" data-operator="<%= ch.operator || 0 %>" data-scope="<%= ch.scope || '' %>"><%= ch.name %></option><% }); %></select></div>
              <div class="form-group"><label>运营商</label><select id="apiOperator-<%= p.id %>"><option value="0">不限</option><option value="1">移动</option><option value="2">联通</option><option value="3">电信</option><option value="4">非虚拟</option></select></div>
              <div class="form-group"><label>手机号（查码/释放用）</label><input id="apiPhoneNum-<%= p.id %>" placeholder="选填或输入完整手机号"></div>
              <div class="form-group"><label>操作</label><div style="display:flex;gap:6px;flex-wrap:wrap"><button class="btn btn-primary" type="button" onclick="apiAction(<%= p.id %>, 'get-phone')">获取号码</button><button class="btn btn-success" type="button" onclick="apiAction(<%= p.id %>, 'get-code')">查验证码</button><button class="btn btn-danger" type="button" onclick="apiAction(<%= p.id %>, 'blacklist')">拉黑</button><button class="btn" type="button" style="background:#f39c12;color:#fff" onclick="apiAction(<%= p.id %>, 'release')">释放</button></div></div>
            </div>
            <div id="apiResult-<%= p.id %>" style="margin-top:12px;padding:12px;border-radius:6px;font-size:13px;min-height:30px;display:none"></div>
          <% } %>
        </div></section>
      <% }); %>
    <% } %>

  </div>

  <div class="modal-overlay" id="addModal"><div class="modal-box"><h3>添加 API 服务商</h3>
    <form method="POST" action="/admin/api-providers/add" class="provider-form">
      <%- include('partials/provider-form-fields', { prefix: 'add', isSystem: false }) %>
      <div class="modal-actions"><button type="button" class="btn btn-cancel" onclick="closeModal('addModal')">取消</button><button class="btn btn-primary">保存</button></div>
    </form>
  </div></div>

  <div class="modal-overlay" id="editModal"><div class="modal-box"><h3>编辑 API 服务商</h3>
    <form method="POST" id="editProviderForm" class="provider-form" data-edit-mode="1">
      <%- include('partials/provider-form-fields', { prefix: 'edit', isSystem: false }) %>
      <div class="modal-actions"><button type="button" class="btn btn-cancel" onclick="closeModal('editModal')">取消</button><button class="btn btn-primary">保存</button></div>
    </form>
  </div></div>

  <script>
    var defaultUrls = { qc86: 'https://api.qc86.shop/api', uoomsg: 'https://api.uoomsg.com/zc/data.php' };
    function syncProviderType(select) {
      var form = select.closest('form');
      var type = select.value;
      form.querySelectorAll('[data-provider-type]').forEach(function(box){ box.style.display = box.dataset.providerType === type ? 'block' : 'none'; });
      var url = form.querySelector('[name="base_url"]');
      if (url && (!url.value || Object.values(defaultUrls).includes(url.value))) url.value = defaultUrls[type];
      form.querySelector('[name="token"]').required = type === 'uoomsg' && form.dataset.editMode !== '1';
    }
    function openAddModal() {
      document.getElementById('addModal').classList.add('show');
      syncProviderType(document.getElementById('addProviderType'));
    }
    function openEditModal(button) {
      var p = JSON.parse(decodeURIComponent(button.dataset.provider));
      var form = document.getElementById('editProviderForm');
      form.action = '/admin/api-providers/edit/' + p.id;
      document.getElementById('editProviderName').value = p.name || '';
      document.getElementById('editProviderType').value = p.provider_type || 'qc86';
      document.getElementById('editBaseUrl').value = p.base_url || '';
      document.getElementById('editUsername').value = '';
      document.getElementById('editPassword').value = '';
      document.getElementById('editToken').value = '';
      document.getElementById('editProviderDescription').value = p.description || '';
      document.getElementById('editProviderActive').value = p.is_active ? '1' : '0';
      document.getElementById('editStripSmsMetadata').checked = Number(p.strip_sms_metadata) !== 0;
      document.getElementById('editProviderType').disabled = Boolean(p.is_system);
      syncProviderType(document.getElementById('editProviderType'));
      document.getElementById('editModal').classList.add('show');
    }
    function closeModal(id) { document.getElementById(id).classList.remove('show'); }
    async function testProvider(id, button) {
      var old = button.textContent;
      button.disabled = true;
      button.textContent = '测试中...';
      try {
        var response = await fetch('/admin/api-providers/test/' + id, { method: 'POST' });
        var data = await response.json();
        alert(data.success
          ? (data.balance == null || data.balance === '' ? (data.message || '连接成功，但服务商未返回余额数值') : '连接成功，余额：' + data.balance)
          : '连接失败：' + data.error);
      } catch (error) { alert('连接失败：' + error.message); }
      button.disabled = false;
      button.textContent = old;
    }

    async function apiAction(providerId, action) {
      var select = document.getElementById('apiChannelId-' + providerId);
      var channelId = select.value;
      if (!channelId) { alert('请选择项目'); return; }
      var phoneInput = document.getElementById('apiPhoneNum-' + providerId);
      var phone = phoneInput.value.trim();
      if ((action === 'get-code' || action === 'blacklist' || action === 'release') && !phone) {
        alert('请填写手机号');
        return;
      }
      var resultBox = document.getElementById('apiResult-' + providerId);
      resultBox.style.display = 'block';
      resultBox.className = 'message message-info';
      resultBox.textContent = '执行中...';
      var option = select.options[select.selectedIndex];
      var params = {
        project_id: channelId,
        channel_id: option.dataset.channelId || '',
        operator: option.dataset.operator || document.getElementById('apiOperator-' + providerId).value,
        scope: option.dataset.scope || ''
      };
      if (phone) params.phone_num = phone;
      if (action === 'blacklist' || action === 'release') params.phone_no = phone;
      try {
        var response = await fetch('/admin/api/' + action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(params)
        });
        var data = await response.json();
        if (data.success && action === 'get-phone' && data.data && data.data.mobile) {
          resultBox.className = 'message message-success';
          resultBox.innerHTML = '获取成功：<strong>' + data.data.mobile + '</strong>';
          phoneInput.value = data.data.mobile;
        } else if (data.success && action === 'get-code' && data.data && data.data.code) {
          resultBox.className = 'message message-success';
          resultBox.innerHTML = '验证码：<strong>' + data.data.code + '</strong>' + (data.data.modle ? '<br>' + data.data.modle : '');
        } else if (data.success) {
          resultBox.className = 'message message-success';
          resultBox.textContent = action === 'blacklist' ? '号码已拉黑' : action === 'release' ? '号码已释放' : '操作成功';
        } else {
          resultBox.className = 'message message-error';
          resultBox.textContent = data.error || data.msg || data.message || '操作失败';
        }
      } catch (error) {
        resultBox.className = 'message message-error';
        resultBox.textContent = '请求失败：' + error.message;
      }
    }

    function showUoomsgResult(providerId, message, kind, raw) {
      var box = document.getElementById('uoomsgResult-' + providerId);
      if (!box) return;
      box.style.display = 'block';
      box.className = 'message message-' + (kind || 'info');
      box.textContent = message || '';
      if (raw) {
        var pre = document.createElement('pre');
        pre.className = 'history-output';
        pre.textContent = raw;
        box.appendChild(pre);
      }
    }

    async function uoomsgAction(providerId, action) {
      var channelId = document.getElementById('uoomsgChannelId-' + providerId);
      var phoneInput = document.getElementById('uoomsgPhone-' + providerId);
      var phone = phoneInput.value.trim();
      var provider = String(providerId || '');
      var project = channelId ? channelId.value : '';
      if (!provider) return showUoomsgResult(providerId, '请选择 uoomsg 服务商', 'error');
      if (['get-phone', 'get-code', 'blacklist', 'release'].includes(action) && !project) return showUoomsgResult(providerId, '请选择 uoomsg 项目', 'error');
      if (['get-code', 'blacklist', 'release'].includes(action) && !phone) return showUoomsgResult(providerId, '请填写手机号', 'error');
      if (action === 'send' && (!phone || !document.getElementById('uoomsgToPhone-' + providerId).value.trim() || !document.getElementById('uoomsgContent-' + providerId).value.trim())) return showUoomsgResult(providerId, '发送短信需要填写手机号、目标号码和内容', 'error');
      if (action === 'get-phone' && !confirm('这会向 uoomsg 请求真实手机号，继续吗？')) return;
      if (action === 'send' && !confirm('这会通过 uoomsg 发送真实短信，继续吗？')) return;
      showUoomsgResult(providerId, '执行中...', 'info');
      var endpoint = action === 'send' ? '/admin/api/uoomsg/send' : action === 'history' ? '/admin/api/uoomsg/history' : action === 'balance' ? '/admin/api/balance' : '/admin/api/' + action;
      var payload = { provider_id: provider, project_id: project, phone_num: phone, phone_no: phone };
      if (action === 'send') {
        payload.toPhone = document.getElementById('uoomsgToPhone-' + providerId).value.trim();
        payload.projId = document.getElementById('uoomsgProjId-' + providerId).value.trim();
        payload.content = document.getElementById('uoomsgContent-' + providerId).value.trim();
      }
      try {
        var response = await fetch(endpoint + (action === 'balance' ? '?provider_id=' + encodeURIComponent(provider) : ''), action === 'balance'
          ? { method: 'GET' }
          : { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        var data = await response.json();
        if (!data.success) return showUoomsgResult(providerId, data.error || data.msg || '操作失败', 'error');
        if (action === 'balance') {
          return showUoomsgResult(providerId,
            data.balance == null || data.balance === '' ? (data.message || '连接成功，但服务商未返回余额数值') : '余额：' + data.balance,
            'success');
        }
        if (action === 'get-phone' && data.data && data.data.mobile) {
          phoneInput.value = data.data.mobile;
          return showUoomsgResult(providerId, '获取成功：' + data.data.mobile, 'success');
        }
        if (action === 'get-code' && data.data && data.data.code) return showUoomsgResult(providerId, '验证码：' + data.data.code + (data.data.modle ? '\n' + data.data.modle : ''), 'success');
        if (action === 'history') return showUoomsgResult(providerId, '历史记录已返回', 'success', data.data && data.data.raw);
        showUoomsgResult(providerId, data.msg || '操作成功', 'success');
      } catch (error) { showUoomsgResult(providerId, '请求失败：' + error.message, 'error'); }
    }

    document.querySelectorAll('[data-provider-tab]').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var providerId = tab.dataset.providerTab;
        document.querySelectorAll('[data-provider-tab]').forEach(function(item) {
          var selected = item === tab;
          item.classList.toggle('is-active', selected);
          item.setAttribute('aria-selected', selected ? 'true' : 'false');
        });
        document.querySelectorAll('[data-provider-panel]').forEach(function(panel) {
          panel.classList.toggle('is-active', panel.dataset.providerPanel === providerId);
        });
      });
    });
  </script>
</body>
</html>
