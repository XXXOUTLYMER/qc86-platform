<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>使用记录 - 卡密接码平台</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('partials/header', { admin, active: 'records' }) %>
  <div class="main">
    <div class="records-page-heading">
      <div>
        <h2>使用记录</h2>
        <p>仅保留接码过程日志；清理不会影响卡密、项目或已分配号码。</p>
      </div>
      <span class="records-page-count">当前 <strong><%= totalCount %></strong> 条</span>
    </div>

    <% if (success) { %><div class="message message-success"><%= success %></div><% } %>
    <% if (error) { %><div class="message message-error"><%= error %></div><% } %>

    <div class="records-tools-card">
      <div class="records-tool-section">
        <div>
          <strong>自动清理</strong>
          <p>网站启动时和每 6 小时自动检查一次旧记录。</p>
        </div>
        <form action="/admin/records/retention" method="POST" class="records-retention-form">
          <label class="sr-only" for="retentionDays">自动保留天数</label>
          <select id="retentionDays" name="retention_days">
            <option value="7" <%= retentionDays === 7 ? 'selected' : '' %>>保留 7 天</option>
            <option value="30" <%= retentionDays === 30 ? 'selected' : '' %>>保留 30 天</option>
            <option value="90" <%= retentionDays === 90 ? 'selected' : '' %>>保留 90 天</option>
            <option value="180" <%= retentionDays === 180 ? 'selected' : '' %>>保留 180 天</option>
            <option value="365" <%= retentionDays === 365 ? 'selected' : '' %>>保留 1 年</option>
            <option value="0" <%= retentionDays === 0 ? 'selected' : '' %>>不自动清理</option>
          </select>
          <button class="btn-apple btn-apple-primary btn-apple-sm" type="submit">保存</button>
        </form>
      </div>
      <div class="records-tool-section records-clear-section">
        <div>
          <strong>清空使用记录</strong>
          <p>只删除日志并压缩数据库；此操作无法恢复。</p>
        </div>
        <form action="/admin/records/clear" method="POST" onsubmit="return confirm('确定要清空全部使用记录吗？卡密和项目不会被删除。');">
          <button class="btn-apple btn-apple-danger btn-apple-sm" type="submit">清空记录</button>
        </form>
      </div>
    </div>

    <div class="records-filter-panel">
      <div class="filter-bar" aria-label="记录状态筛选">
        <% const filterItems = [['all', '全部'], ['pending', '等待中'], ['completed', '已完成'], ['timeout', '超时']]; %>
        <% filterItems.forEach(function(item) { %>
          <a class="filter-chip <%= status === item[0] ? 'active' : '' %>" href="/admin/records?status=<%= item[0] %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"><%= item[1] %></a>
        <% }); %>
      </div>
      <form action="/admin/records" method="GET" class="records-search">
        <input type="hidden" name="status" value="<%= status %>">
        <input name="q" value="<%= q %>" placeholder="搜索卡密、项目、手机号或验证码" autocomplete="off">
        <% if (q) { %><a class="records-search-clear" href="/admin/records?status=<%= status %>" aria-label="清除搜索">×</a><% } %>
        <button class="btn-apple btn-apple-secondary btn-apple-sm" type="submit">搜索</button>
      </form>
    </div>

    <div class="records-result-hint">找到 <strong><%= resultCount %></strong> 条记录<%= resultCount > records.length ? '，当前显示最近 ' + records.length + ' 条' : '' %></div>
    <div class="card records-list-card">
      <div class="card-body">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>卡密</th>
                <th>项目</th>
                <th>手机号</th>
                <th>验证码</th>
                <th>状态</th>
                <th>时间</th>
              </tr>
            </thead>
            <tbody>
              <% if (records.length === 0) { %>
              <tr><td colspan="7" class="empty"><%= q || status !== 'all' ? '没有符合条件的使用记录' : '暂无使用记录' %></td></tr>
              <% } else { records.forEach(r => { %>
              <tr>
                <td data-label="ID"><%= r.id %></td>
                <td data-label="卡密" style="font-family:monospace;font-size:12px"><%= r.card_code %></td>
                <td data-label="项目"><%= r.channel_name %></td>
                <td data-label="手机号" style="font-family:monospace;font-size:12px"><%= r.phone_number %></td>
                <td data-label="验证码" style="font-family:monospace;font-size:14px;font-weight:bold;color:#e74c3c"><%= r.sms_code || '-' %></td>
                <td data-label="状态">
                  <span class="badge badge-<%= r.status === 'completed' ? 'unused' : r.status === 'pending' ? 'expired' : 'used' %>">
                    <%= {'completed':'已完成','pending':'等待中','timeout':'超时'}[r.status] || r.status %>
                  </span>
                </td>
                <td data-label="时间"><%= r.created_at %></td>
              </tr>
              <% }) } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
