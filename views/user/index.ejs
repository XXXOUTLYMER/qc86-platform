  <!-- ===== LOADING SCREEN HIDE SCRIPT ===== -->
  <script>
  (function() {
    var overlay = document.getElementById('loadingOverlay');
    if (overlay) {
      var overlayHideTimer = null;

      window.qc86ShowLoadingOverlay = function(message) {
        var fill = overlay.querySelector('.loading-fill');
        var text = overlay.querySelector('.loader-text');
        if (overlayHideTimer) {
          clearTimeout(overlayHideTimer);
          overlayHideTimer = null;
        }
        overlay.classList.remove('is-arriving');
        overlay.classList.add('is-submitting');
        overlay.classList.remove('hidden');
        overlay.setAttribute('aria-hidden', 'false');
        if (text && message) text.textContent = message;
        if (fill) {
          fill.style.animation = 'none';
          void fill.offsetWidth;
          fill.style.animation = '';
        }
      };

      window.qc86HideLoadingOverlay = function() {
        var hideDuration = overlay.classList.contains('is-arriving') ? 680 : 260;
        overlay.classList.add('hidden');
        overlay.setAttribute('aria-hidden', 'true');
        overlayHideTimer = setTimeout(function() {
          overlay.classList.remove('is-submitting');
          overlay.classList.remove('is-arriving');
          document.body.classList.remove('transition-arrival');
          overlayHideTimer = null;
        }, hideDuration);
      };

      // Let the centered phone complete its green screen-fill reveal.
      if (!overlay.classList.contains('hidden')) {
        var startTime = Date.now();
        var isArrivalTransition = overlay.classList.contains('is-arriving');
        var hideStarted = false;
        function hideLoading() {
          if (hideStarted) return;
          hideStarted = true;
          var elapsed = Date.now() - startTime;
          var minimumVisibleTime = isArrivalTransition ? 760 : 1120;
          var delay = Math.max(0, minimumVisibleTime - elapsed);
          setTimeout(function() {
            window.qc86HideLoadingOverlay();
            setTimeout(function() {
              window.dispatchEvent(new CustomEvent('qc86:loading-complete'));
            }, isArrivalTransition ? 700 : 320);
          }, delay);
        }
        if (document.readyState === 'complete') {
          hideLoading();
        } else {
          window.addEventListener('load', hideLoading);
          // Fallback keeps the page accessible even if a resource stalls.
          setTimeout(hideLoading, 2400);
        }
      }
    }
  })();
  </script>

  <!-- Auto-fill card code from URL parameter -->
