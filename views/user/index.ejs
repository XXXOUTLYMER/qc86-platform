  (function() {
    var params = new URLSearchParams(window.location.search);
    var cardCode = params.get('card');
    if (cardCode) {
      var input = document.getElementById('card_code');
      if (input) {
        input.value = cardCode.toUpperCase();
        input.dispatchEvent(new Event('input'));
        setTimeout(function() {
          input.scrollIntoView({ behavior: 'smooth' });
        }, 500);
      }
    }
  })();
  </script>

 <!-- Waiting step scripts -->
 <% if (step === 'filtering') { %>
 <script>
   (function() {
     var cardId = <%- JSON.stringify(String(cardId || '')) %>;
     var cardCode = <%- JSON.stringify(String(cardCode || '')) %>;
     var message = document.getElementById('filterMessage');
     var count = document.getElementById('filterRequestCount');
     var max = document.getElementById('filterMaxRequests');
     var back = document.getElementById('filterBack');
     var pollTimer = null;
     var pollController = null;
     var pollInFlight = false;
     var stopped = false;
     var redirecting = false;
     var lastStatus = '';

     function setMessage(text) {
       if (message && text) message.textContent = text;
     }

     function stopPolling() {
       stopped = true;
       if (pollTimer) {
         window.clearTimeout(pollTimer);
         pollTimer = null;
       }
       if (pollController) {
         pollController.abort();
         pollController = null;
       }
     }

     function schedulePoll(delay) {
       if (stopped || redirecting || document.visibilityState === 'hidden') return;
       if (pollTimer) window.clearTimeout(pollTimer);
       pollTimer = window.setTimeout(pollStatus, delay);
     }

     async function pollStatus() {
       pollTimer = null;
       if (stopped || redirecting || document.visibilityState === 'hidden') return;
       if (pollInFlight) {
         schedulePoll(250);
         return;
       }
       pollInFlight = true;
       pollController = typeof AbortController === 'function' ? new AbortController() : null;

       try {
         var response = await fetch('/phone-request-status/' + encodeURIComponent(cardId), {
           cache: 'no-store',
           signal: pollController ? pollController.signal : undefined
         });
         if (!response.ok) throw new Error('状态请求失败');
         var data = await response.json();
         if (stopped) return;

         if (!data.found) {
           setMessage('卡密不存在或已被删除');
           if (back) back.style.display = 'inline-flex';
           stopPolling();
           return;
         }

         var statusKey = [data.state, data.message, data.requestCount, data.maxRequests].join('|');
         if (statusKey !== lastStatus) {
           lastStatus = statusKey;
           setMessage(data.message || '正在逐个筛选号码，请稍候');
           if (count) count.textContent = Math.max(0, Number(data.requestCount) || 0);
           if (max) max.textContent = Math.max(1, Number(data.maxRequests) || 1);
         }

         if (data.state === 'success' && data.phoneNumber && !redirecting) {
           redirecting = true;
           stopPolling();
           if (window.qc86ShowLoadingOverlay) {
             window.qc86ShowLoadingOverlay('号码已准备好');
           }
           try { window.sessionStorage.setItem('qc86:page-transition', '1'); } catch (e) {}
           window.requestAnimationFrame(function() {
             window.requestAnimationFrame(function() {
               window.setTimeout(function() {
                 window.location.replace('/?card=' + encodeURIComponent(data.cardCode || cardCode));
               }, window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 80 : 760);
             });
           });
           return;
         }
         if (data.state === 'failed') {
           if (back) back.style.display = 'inline-flex';
           stopPolling();
           return;
         }
         schedulePoll(1200);
       } catch (error) {
         if (!stopped && !(error && error.name === 'AbortError')) {
           setMessage('网络连接暂时不稳定，正在继续等待筛选结果');
           schedulePoll(1800);
         } else if (!stopped && document.visibilityState === 'visible') {
           schedulePoll(250);
         }
       } finally {
         pollInFlight = false;
         pollController = null;
       }
     }

     // Do not let a very fast result navigate away before the loading layer has
     // painted. This makes the handoff from card entry to the number screen visible.
     var pollingStarted = false;
     function startPollingAfterTransition() {
       if (pollingStarted) return;
       pollingStarted = true;
       pollStatus();
     }
     window.addEventListener('qc86:loading-complete', startPollingAfterTransition, { once: true });
     window.setTimeout(startPollingAfterTransition, 1600);
     document.addEventListener('visibilitychange', function() {
       if (document.visibilityState === 'hidden') {
         if (pollController) pollController.abort();
         if (pollTimer) {
           window.clearTimeout(pollTimer);
           pollTimer = null;
         }
       } else if (!stopped && !redirecting) {
         schedulePoll(0);
       }
     });
     window.addEventListener('pagehide', stopPolling, { once: true });
   })();
 </script>
 <% } %>

 <!-- Waiting step scripts -->
 <% if (step === 'waiting') { %>
 <script>
   var cardId = <%- JSON.stringify(String(cardId || '')) %>;
   var interval = <%= refreshInterval || 5000 %>;
	   var hasSms = <%= smsCode ? 'true' : 'false' %>;
	   var isPreviewMode = <%= (typeof previewMode !== 'undefined' && previewMode) ? 'true' : 'false' %>;
	   var previewPhoneIndex = 47;
	   var previewAttempt = <%= typeof attempts !== "undefined" ? attempts : 1 %>;
	   var previewMaxAttempts = <%= typeof maxAttempts !== "undefined" ? maxAttempts : 3 %>;

    // Update URL to include card code so refresh restores the waiting state
    if (!isPreviewMode && window.history && window.history.replaceState) {
      window.history.replaceState({ cardCode: <%- JSON.stringify(cardCode) %> }, '', '/?card=' + <%- JSON.stringify(cardCode || '') %>);
    }
    // Save card_id to localStorage as extra safety (survives full tab close)
    if (!isPreviewMode && window.localStorage) {
      try { localStorage.setItem('lastCardCode', <%- JSON.stringify(cardCode || '') %>); } catch(e) {}
    }

    // Poll only while this page is visible. Stop immediately after a code is
    // stored, otherwise a long-open tab keeps making unnecessary requests.
    if (!hasSms && !isPreviewMode) {
      var smsPollTimer = null;
      var smsPollInFlight = false;

      function stopSmsPolling() {
        if (smsPollTimer) {
          window.clearInterval(smsPollTimer);
          smsPollTimer = null;
        }
      }

      function checkSms() {
        if (smsPollInFlight || document.visibilityState === 'hidden') return;
        smsPollInFlight = true;
        fetch('/check-sms/' + cardId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.found && data.smsCode) {
              stopSmsPolling();
              var w = document.getElementById('smsWaiting');
              var s = document.getElementById('smsSuccess');
              if (w) w.style.display = 'none';
              if (s) s.style.display = 'block';
              var el = document.getElementById('smsResult');
              if (el) {
                el.style.display = 'block';
                var codeEl = el.querySelector('.value.sms-code');
                var msgEl = el.querySelector('.msg-text');
                if (codeEl) codeEl.textContent = data.smsCode;
                if (msgEl) msgEl.textContent = data.smsMessage || '';
                document.dispatchEvent(new CustomEvent('qc86:sms-available', {
                  detail: { code: data.smsCode }
                }));
              }
            }
          })
          .catch(function() {})
          .then(function() { smsPollInFlight = false; });
      }
      checkSms();
      smsPollTimer = window.setInterval(checkSms, Math.max(interval, 3000));
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'visible') checkSms();
      });
      window.addEventListener('pagehide', stopSmsPolling, { once: true });
    }

    // The server is the source of truth for cooldowns. This keeps refreshes,
    // failed duplicate clicks, and successful number changes in sync.
    var cooldownTimer = null;
    function applyCooldown(seconds, remainingAttempts) {
      var countdownEl = document.getElementById('countdownSeconds');
      var countdownText = document.getElementById('countdownText');
      var getBtn = document.getElementById('getNewPhoneBtn');
      var remainingSeconds = Math.max(0, Math.ceil(Number(seconds) || 0));
      var attemptsLeft = Math.max(0, Number(remainingAttempts) || 0);

      if (cooldownTimer) {
        clearInterval(cooldownTimer);
        cooldownTimer = null;
      }
      if (!countdownEl || !countdownText || !getBtn) return;

      countdownEl.textContent = remainingSeconds;
      if (remainingSeconds <= 0) {
        countdownText.style.display = 'none';
        getBtn.style.display = attemptsLeft > 0 ? 'inline-flex' : 'none';
        return;
      }

      countdownText.style.display = 'block';
      getBtn.style.display = 'none';
      cooldownTimer = setInterval(function() {
        remainingSeconds--;
        countdownEl.textContent = Math.max(remainingSeconds, 0);
        if (remainingSeconds <= 0) {
          clearInterval(cooldownTimer);
          cooldownTimer = null;
          countdownText.style.display = 'none';
          getBtn.style.display = attemptsLeft > 0 ? 'inline-flex' : 'none';
        }
      }, 1000);
    }

    if (!hasSms && document.getElementById('countdownSeconds')) {
      applyCooldown(
        <%= typeof cooldownRemaining !== "undefined" ? cooldownRemaining : (typeof cooldownSeconds !== "undefined" ? cooldownSeconds : 60) %>,
        <%= (typeof maxAttempts !== "undefined" ? maxAttempts : 3) - (typeof attempts !== "undefined" ? attempts : 1) %>
      );
    }

    // Get new phone number
    async function getNewPhone() {
      var btn = document.getElementById('getNewPhoneBtn');
      if (!btn || btn.disabled) return;
      var originalButtonHtml = btn.innerHTML;
      var loadingStartedAt = Date.now();

      function finishPhoneLoading(callback) {
        var remainingAnimationTime = Math.max(0, 1120 - (Date.now() - loadingStartedAt));
        window.setTimeout(function() {
          if (window.qc86HideLoadingOverlay) window.qc86HideLoadingOverlay();
          if (callback) callback();
        }, remainingAnimationTime);
      }

      btn.disabled = true;
      btn.classList.add('is-loading');
      btn.innerHTML = '<span class="spinner" style="width:14px;height:14px;border-width:2px;margin:0"></span> 获取中...';
      if (window.qc86ShowLoadingOverlay) {
        window.qc86ShowLoadingOverlay('正在获取新号码');
      }

      if (isPreviewMode) {
        window.setTimeout(function() {
          previewPhoneIndex++;
          var phoneEl = document.getElementById('currentPhone');
          var counterEl = document.getElementById('remainingCounter');
          var remEl = document.getElementById('remainingAttempts');
          previewAttempt++;
          var remaining = Math.max(previewMaxAttempts - previewAttempt, 0);

          if (phoneEl) phoneEl.textContent = '138000000' + previewPhoneIndex;
          if (counterEl) counterEl.textContent = remaining;
          if (remEl) remEl.textContent = remaining;
          btn.classList.remove('is-loading');
          btn.disabled = false;
          btn.innerHTML = '获取新号码（剩余 <span id="remainingAttempts">' + remaining + '</span> 次）';
          btn.style.display = remaining > 0 ? 'inline-flex' : 'none';
          finishPhoneLoading(function() {
            showToast('已切换本地模拟号码');
          });
        }, 450);
        return;
      }

      try {
        var resp = await fetch('/get-new-phone', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ card_id: cardId })
        });
        var data = await resp.json();

        if (data.success && data.pending) {
          try { window.sessionStorage.setItem('qc86:page-transition', '1'); } catch (e) {}
          // Wait for two frames before navigating so the full-screen phone
          // animation can actually paint instead of disappearing immediately.
          var targetUrl = '/?card=' + encodeURIComponent(data.cardCode || <%- JSON.stringify(cardCode || '') %>);
          var transitionDelay = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 80 : 1060;
          window.requestAnimationFrame(function() {
            window.requestAnimationFrame(function() {
              window.setTimeout(function() {
                window.location.assign(targetUrl);
              }, transitionDelay);
            });
          });
          return;
        }

        if (data.success) {
          var phoneEl = document.getElementById('currentPhone');
          if (phoneEl) {
            phoneEl.classList.remove('num-transition');
            void phoneEl.offsetWidth;
            phoneEl.textContent = data.phoneNumber;
            phoneEl.classList.add('num-transition');
          }

          var remaining = data.maxAttempts - data.attempts;
          var counterEl = document.getElementById('remainingCounter');
          if (counterEl) counterEl.textContent = Math.max(remaining, 0);
          var remEl = document.getElementById('remainingAttempts');
          if (remEl) remEl.textContent = remaining;

          var newBtn = document.getElementById('getNewPhoneBtn');
          if (newBtn) {
            newBtn.classList.remove('is-loading');
            newBtn.disabled = false;
            newBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> 获取新号码（剩余 ' + remaining + ' 次）';
          }
          applyCooldown(data.cooldownRemaining, remaining);
          finishPhoneLoading();
        } else {
          showToast(data.error || '获取失败');
          if (data.currentPhone) {
            var phoneEl = document.getElementById('currentPhone');
            if (phoneEl) phoneEl.textContent = data.currentPhone;
          }
          if (typeof data.cooldownRemaining !== 'undefined') {
            var retryRemaining = Number(data.maxAttempts) - Number(data.attempts);
            applyCooldown(data.cooldownRemaining, retryRemaining);
          }
          btn.classList.remove('is-loading');
          btn.innerHTML = originalButtonHtml;
          btn.disabled = false;
          finishPhoneLoading();
        }
      } catch(e) {
        showToast('请求失败');
        btn.classList.remove('is-loading');
        btn.innerHTML = originalButtonHtml;
        btn.disabled = false;
        finishPhoneLoading();
      }
    }

    function copyPhoneNumber() {
      var phoneEl = document.getElementById('currentPhone');
      if (!phoneEl) return;
      var phone = phoneEl.textContent.trim();
      if (!phone) return;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(phone).then(function() {
          markPhoneCopied();
          showToast('\u2705 \u5df2\u590d\u5236\u624b\u673a\u53f7');
        }).catch(function() {
          showToast('\u590d\u5236\u5931\u8d25\uff0c\u8bf7\u624b\u52a8\u590d\u5236');
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = phone;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
          markPhoneCopied();
          showToast('\u2705 \u5df2\u590d\u5236\u624b\u673a\u53f7');
        } catch(e) {
          showToast('\u590d\u5236\u5931\u8d25\uff0c\u8bf7\u624b\u52a8\u590d\u5236');
        }
        document.body.removeChild(ta);
      }
    }

    function markPhoneCopied() {
      var btn = document.getElementById('copyPhoneBtn');
      if (!btn) return;
      btn.classList.add('copied');
      btn.setAttribute('title', '\u5df2\u590d\u5236');
      window.setTimeout(function() {
        btn.classList.remove('copied');
        btn.setAttribute('title', '\u590d\u5236\u624b\u673a\u53f7');
      }, 1100);
    }

    function showToast(msg) {
      var existing = document.querySelector('.toast');
      if (existing) existing.remove();
      var t = document.createElement('div');
      t.className = 'toast';
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 2500);
    }
  </script>
  <% } %>

  <!-- ===== INTERACTIVE EFFECTS ===== -->
  <script>
  (function() {
    'use strict';

    // ---- 1. SMS success side-spray ----
    (function() {
      var canvas = document.getElementById('successParticles');
      if (!canvas || !canvas.getContext) return;
      var ctx = canvas.getContext('2d');
      var particles = [];
      var frame = 0;
      var active = false;
      var colors = ['#28e56f', '#70f39a', '#12b956', '#baffcf', '#ffffff'];

      function resize() {
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.floor(window.innerWidth * dpr);
        canvas.height = Math.floor(window.innerHeight * dpr);
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resize();
      window.addEventListener('resize', resize, { passive: true });

      window.launchSuccessParticles = function(force) {
        if (!force && window.__smsParticlesShown) return;
        window.__smsParticlesShown = true;
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        if (active) return;
        active = true;
        particles = [];
        var y = Math.min(Math.max(window.innerHeight * 0.54, 150), window.innerHeight - 120);
        for (var side = 0; side < 2; side++) {
          for (var i = 0; i < 34; i++) {
            var fromLeft = side === 0;
            particles.push({
              x: fromLeft ? -10 - Math.random() * 24 : window.innerWidth + 10 + Math.random() * 24,
              y: y + (Math.random() - 0.5) * 72,
              vx: (fromLeft ? 1 : -1) * (2.3 + Math.random() * 4.8),
              vy: (Math.random() - 0.5) * 5.2,
              gravity: 0.06 + Math.random() * 0.05,
              size: 2 + Math.random() * 4,
              length: 5 + Math.random() * 10,
              rotation: Math.random() * Math.PI,
              spin: (Math.random() - 0.5) * 0.18,
              life: 1,
              decay: 0.010 + Math.random() * 0.010,
              color: colors[Math.floor(Math.random() * colors.length)]
            });
          }
        }

        var started = performance.now();
        cancelAnimationFrame(frame);
        function animate(now) {
          var elapsed = now - started;
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
          particles.forEach(function(p) {
            p.x += p.vx;
            p.y += p.vy;
            p.vy += p.gravity;
            p.rotation += p.spin;
            p.life -= p.decay;
            if (p.life <= 0) return;
            ctx.save();
            ctx.globalAlpha = Math.max(0, Math.min(1, p.life * 1.25));
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rotation);
            ctx.fillStyle = p.color;
            ctx.fillRect(-p.length / 2, -p.size / 2, p.length, p.size);
            ctx.restore();
          });
          if (elapsed < 2100) {
            frame = requestAnimationFrame(animate);
          } else {
            ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            particles = [];
            active = false;
          }
        }
        frame = requestAnimationFrame(animate);
      };
    })();

    // ---- 2. Mouse parallax for background orbs ----
    var orbs = document.querySelectorAll('.bg-orb');
    if (orbs.length && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      var orbData = [];
      var orbFrame = 0;
      orbs.forEach(function(o) {
        orbData.push({
          el: o,
          x: 0, y: 0,
          targetX: 0, targetY: 0,
          speed: 0.03 + Math.random() * 0.02
        });
      });
      function animateOrbs() {
        var stillMoving = false;
        orbData.forEach(function(o) {
          var dx = o.targetX - o.x;
          var dy = o.targetY - o.y;
          o.x += dx * o.speed;
          o.y += dy * o.speed;
          if (Math.abs(dx) > 0.12 || Math.abs(dy) > 0.12) stillMoving = true;
          o.el.style.transform = 'translate(' + o.x.toFixed(1) + 'px, ' + o.y.toFixed(1) + 'px)';
        });
        orbFrame = stillMoving && document.visibilityState === 'visible'
          ? window.requestAnimationFrame(animateOrbs)
          : 0;
      }
      function scheduleOrbMotion() {
        if (!orbFrame && document.visibilityState === 'visible') {
          orbFrame = window.requestAnimationFrame(animateOrbs);
        }
      }
      document.addEventListener('mousemove', function(e) {
        var cx = e.clientX / window.innerWidth - 0.5;
        var cy = e.clientY / window.innerHeight - 0.5;
        orbData.forEach(function(o, i) {
          o.targetX = cx * (35 + i * 18);
          o.targetY = cy * (35 + i * 18);
        });
        scheduleOrbMotion();
      });
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'hidden' && orbFrame) {
          window.cancelAnimationFrame(orbFrame);
          orbFrame = 0;
        }
      });
    }

    // ---- 3. Button ripple effect ----
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.btn');
      if (!btn || btn.disabled) return;
      var rect = btn.getBoundingClientRect();
      var ripple = document.createElement('span');
      ripple.className = 'ripple-effect';
      var size = Math.max(rect.width, rect.height);
      ripple.style.width = ripple.style.height = size + 'px';
      ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
      ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
      btn.appendChild(ripple);
      setTimeout(function() { ripple.remove(); }, 700);
    });

    // ---- 3b. Interactive telephone-pattern background ----
    var phonePattern = document.getElementById('phonePattern');
    if (phonePattern) {
      var phoneDoodles = Array.prototype.slice.call(phonePattern.querySelectorAll('.phone-doodle'));
      var interactiveDoodles = [];
      var phonePatternFrame = 0;
      var pointerX = window.innerWidth / 2;
      var pointerY = window.innerHeight / 2;
      var resetPhonePatternTimer = 0;
      var supportsFinePointer = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      // Keep the decoration responsive: measuring every icon on every pointer
      // move forces browser layout work right when the card form is used.
      function measurePhoneDoodles() {
        interactiveDoodles = phoneDoodles
          .filter(function(_, index) { return index % 2 === 0; })
          .map(function(doodle) {
            var rect = doodle.getBoundingClientRect();
            return {
              el: doodle,
              x: rect.left + rect.width / 2,
              y: rect.top + rect.height / 2,
              opacity: parseFloat(doodle.style.getPropertyValue('--base-opacity')) || 0.1
            };
          });
      }
      measurePhoneDoodles();
      window.addEventListener('resize', measurePhoneDoodles, { passive: true });

      function resetPhonePattern() {
        phoneDoodles.forEach(function(doodle) {
          doodle.classList.remove('is-near');
          doodle.style.removeProperty('--react-x');
          doodle.style.removeProperty('--react-y');
          doodle.style.removeProperty('--doodle-scale');
          doodle.style.removeProperty('--doodle-glow');
          doodle.style.removeProperty('--doodle-opacity');
        });
        phonePattern.style.setProperty('--touch-pulse', '0');
      }

      function updatePhonePattern() {
        phonePatternFrame = 0;
        phonePattern.style.setProperty('--pointer-x', (pointerX / window.innerWidth * 100).toFixed(1) + '%');
        phonePattern.style.setProperty('--pointer-y', (pointerY / window.innerHeight * 100).toFixed(1) + '%');

        interactiveDoodles.forEach(function(item) {
          var doodle = item.el;
          var dx = pointerX - item.x;
          var dy = pointerY - item.y;
          var distance = Math.sqrt(dx * dx + dy * dy);
          var strength = Math.max(0, 1 - distance / 155);
          var baseOpacity = item.opacity;

          doodle.classList.toggle('is-near', strength > 0.08);
          doodle.style.setProperty('--react-x', (dx * strength * 0.035).toFixed(2) + 'px');
          doodle.style.setProperty('--react-y', (dy * strength * 0.035).toFixed(2) + 'px');
          doodle.style.setProperty('--doodle-scale', (1 + strength * 0.18).toFixed(3));
          doodle.style.setProperty('--doodle-glow', (strength * 16).toFixed(1) + 'px');
          doodle.style.setProperty('--doodle-opacity', Math.min(0.76, baseOpacity + strength * 0.60).toFixed(3));
        });
      }

      document.addEventListener('pointermove', function(e) {
        if (!supportsFinePointer || e.pointerType !== 'mouse') return;
        pointerX = e.clientX;
        pointerY = e.clientY;
        if (!phonePatternFrame) phonePatternFrame = window.requestAnimationFrame(updatePhonePattern);
      }, { passive: true });
      document.addEventListener('pointerdown', function(e) {
        pointerX = e.clientX;
        pointerY = e.clientY;
        phonePattern.style.setProperty('--touch-pulse', e.pointerType === 'mouse' ? '0' : '1');
        if (supportsFinePointer && !phonePatternFrame) {
          phonePatternFrame = window.requestAnimationFrame(updatePhonePattern);
        } else if (!supportsFinePointer) {
          phonePattern.style.setProperty('--pointer-x', (pointerX / window.innerWidth * 100).toFixed(1) + '%');
          phonePattern.style.setProperty('--pointer-y', (pointerY / window.innerHeight * 100).toFixed(1) + '%');
        }
        window.clearTimeout(resetPhonePatternTimer);
      }, { passive: true });
      document.addEventListener('pointerup', function(e) {
        if (e.pointerType === 'mouse') return;
        window.clearTimeout(resetPhonePatternTimer);
        resetPhonePatternTimer = window.setTimeout(resetPhonePattern, 280);
      }, { passive: true });
      document.addEventListener('pointercancel', resetPhonePattern, { passive: true });
      document.documentElement.addEventListener('mouseleave', resetPhonePattern);
      window.addEventListener('blur', resetPhonePattern);
    }

    // ---- 3c. Decorative emoji proximity and tap feedback ----
    var emojiChips = document.querySelectorAll('.emoji-chip');
    if (emojiChips.length) {
      var finePointer = window.matchMedia && window.matchMedia('(pointer: fine)').matches;

      if (finePointer) {
        document.addEventListener('pointermove', function(e) {
          emojiChips.forEach(function(chip) {
            var rect = chip.getBoundingClientRect();
            var cx = rect.left + rect.width / 2;
            var cy = rect.top + rect.height / 2;
            var dx = e.clientX - cx;
            var dy = e.clientY - cy;
            var distance = Math.sqrt(dx * dx + dy * dy);
            var isNear = distance < 120;
            chip.classList.toggle('is-near', isNear);
            chip.style.setProperty('--chip-x', isNear ? Math.max(-3, Math.min(3, dx * 0.025)).toFixed(1) + 'px' : '0px');
            chip.style.setProperty('--chip-y', isNear ? Math.max(-3, Math.min(3, dy * 0.025)).toFixed(1) + 'px' : '0px');
          });
        }, { passive: true });
      }

      emojiChips.forEach(function(chip) {
        chip.addEventListener('pointerdown', function() {
          chip.classList.remove('is-active');
          void chip.offsetWidth;
          chip.classList.add('is-active');

          for (var i = 0; i < 6; i++) {
            var spark = document.createElement('i');
            var angle = (Math.PI * 2 * i / 6) + Math.random() * 0.35;
            var distance = 18 + Math.random() * 13;
            spark.className = 'emoji-spark';
            spark.style.setProperty('--spark-x', Math.cos(angle) * distance + 'px');
            spark.style.setProperty('--spark-y', Math.sin(angle) * distance + 'px');
            chip.appendChild(spark);
            window.setTimeout(function(node) { node.remove(); }, 620, spark);
          }

          window.setTimeout(function() { chip.classList.remove('is-active'); }, 540);
        });
      });

      var bottomEmojiRail = document.querySelector('.emoji-rail.bottom');
      var mainGlass = document.querySelector('main.glass');
      if (bottomEmojiRail && mainGlass) {
        var emojiRailFrame = 0;
        function updateBottomEmojiRail() {
          emojiRailFrame = 0;
          if (!window.matchMedia('(max-width: 768px)').matches) {
            bottomEmojiRail.classList.remove('is-obscured');
            return;
          }

          var glassRect = mainGlass.getBoundingClientRect();
          var railStyle = window.getComputedStyle(bottomEmojiRail);
          var railBottom = parseFloat(railStyle.bottom) || 10;
          var railTop = window.innerHeight - railBottom - bottomEmojiRail.offsetHeight;
          var overlapsGlass = glassRect.bottom > railTop - 8 && glassRect.top < window.innerHeight;
          bottomEmojiRail.classList.toggle('is-obscured', overlapsGlass);
        }
        function scheduleBottomEmojiRailUpdate() {
          if (!emojiRailFrame) emojiRailFrame = window.requestAnimationFrame(updateBottomEmojiRail);
        }

        window.addEventListener('scroll', scheduleBottomEmojiRailUpdate, { passive: true });
        window.addEventListener('resize', scheduleBottomEmojiRailUpdate);
        updateBottomEmojiRail();
      }
    }

    // ---- 4. Shake error boxes on appearance ----
    var errorBox = document.querySelector('.error-box');
    if (errorBox) {
      errorBox.classList.add('shake');
      setTimeout(function() { errorBox.classList.remove('shake'); }, 600);
    }

    // ---- 5. SMS code reminder: replay when the customer returns to the tab ----
    (function() {
      var target = document.getElementById('smsResult');
      if (!target) return;
      var lastReminderAt = 0;

      function playSmsReminder() {
        if (target.style.display === 'none') return;
        var now = Date.now();
        if (now - lastReminderAt < 1800) return;
        lastReminderAt = now;
        target.classList.remove('pulse-glow');
        void target.offsetWidth;
        target.classList.add('pulse-glow');
        if (window.launchSuccessParticles) window.launchSuccessParticles(true);
        setTimeout(function() { target.classList.remove('pulse-glow'); }, 4500);
      }

      var obs = new MutationObserver(function() {
        playSmsReminder();
      });
      obs.observe(target, { attributes: true, attributeFilter: ['style'] });

      document.addEventListener('qc86:sms-available', function() {
        window.setTimeout(playSmsReminder, 120);
      });
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'visible') window.setTimeout(playSmsReminder, 360);
      });
      window.addEventListener('focus', function() {
        window.setTimeout(playSmsReminder, 360);
      });
      window.addEventListener('pageshow', function() {
        window.setTimeout(playSmsReminder, 360);
      });

      // A saved code is treated as a reminder on every return, rather than a
      // one-time animation the customer can miss while switching apps.
      if (target.style.display !== 'none') {
        var playInitialSuccess = function() {
          setTimeout(playSmsReminder, 160);
        };

        if (document.getElementById('loadingOverlay')) {
          window.addEventListener('qc86:loading-complete', playInitialSuccess, { once: true });
        } else {
          playInitialSuccess();
        }
      }
    })();

    // ---- 6. Auto-scroll to card input ----
    var cardInput = document.getElementById('card_code');
    if (cardInput) {
      setTimeout(function() {
        cardInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 400);
    }

    // ---- 7. Countdown ring progress ----
    var countdownRing = document.getElementById('countdownRing');
    if (countdownRing) {
      var ringCircle = countdownRing.querySelector('.progress-ring');
      if (ringCircle) {
        var ringRadius = 22;
        var circumference = 2 * Math.PI * ringRadius;
        ringCircle.style.strokeDasharray = circumference;
        ringCircle.style.strokeDashoffset = '0';
        var originalSeconds = parseInt(countdownRing.getAttribute('data-total')) || 60;
        var ringTimer = setInterval(function() {
          var secEl = document.getElementById('countdownSeconds');
          if (!secEl) { clearInterval(ringTimer); return; }
          var currentSec = parseInt(secEl.textContent) || 0;
          var progress = currentSec / originalSeconds;
          ringCircle.style.strokeDashoffset = (circumference * (1 - progress)).toFixed(1);
          if (currentSec <= 0) {
            clearInterval(ringTimer);
            ringCircle.style.strokeDashoffset = '0';
          }
        }, 250);
      }
    }

    // ---- 8. Glass light follows fine-pointer movement ----
    var glass = document.querySelector('.glass');
    if (glass && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      glass.addEventListener('mousemove', function(e) {
        var rect = glass.getBoundingClientRect();
        var px = (e.clientX - rect.left) / rect.width;
        var py = (e.clientY - rect.top) / rect.height;
        var x = px - 0.5;
        var y = py - 0.5;
        glass.style.setProperty('--glass-x', (px * 100).toFixed(1) + '%');
        glass.style.setProperty('--glass-y', (py * 100).toFixed(1) + '%');
        glass.style.transform =
          'perspective(1000px) rotateY(' + (x * 1.8).toFixed(2) + 'deg) rotateX(' + (-y * 1.5).toFixed(2) + 'deg) translateY(-1px)';
      });
      glass.addEventListener('mouseleave', function() {
        glass.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)';
        glass.style.setProperty('--glass-x', '50%');
        glass.style.setProperty('--glass-y', '0%');
      });
    }

    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      document.addEventListener('mousemove', function(e) {
        document.body.style.setProperty('--page-x', (e.clientX / window.innerWidth * 100).toFixed(1) + '%');
        document.body.style.setProperty('--page-y', (e.clientY / window.innerHeight * 100).toFixed(1) + '%');
      });
    }

    var redeemForm = document.getElementById('cardForm');
    var redeemButton = document.getElementById('redeemButton');
    if (redeemForm && redeemButton) {
      var redeemSubmitting = false;
      redeemForm.addEventListener('submit', function(event) {
        if (redeemSubmitting) return;
        event.preventDefault();
        redeemSubmitting = true;
        redeemButton.disabled = true;
        redeemButton.classList.add('is-loading');
        var label = redeemButton.querySelector('.btn-label');
        if (label) label.textContent = '正在连接';
        try {
          window.sessionStorage.setItem('qc86:page-transition', '1');
        } catch (e) {}
        if (window.qc86ShowLoadingOverlay) {
          window.qc86ShowLoadingOverlay('正在获取号码');
        }
        var transitionDelay = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 120 : 980;
        window.requestAnimationFrame(function() {
          window.requestAnimationFrame(function() {
            window.setTimeout(function() {
              HTMLFormElement.prototype.submit.call(redeemForm);
            }, transitionDelay);
          });
        });
      });
    }

    // ---- 9. Brand icon idle pulse ----
    var brandIcon = document.querySelector('.brand-icon');
    if (brandIcon) {
      var pulseInterval;
      brandIcon.addEventListener('mouseenter', function() {
        clearInterval(pulseInterval);
      });
      brandIcon.addEventListener('mouseleave', function() {
        var count = 0;
        pulseInterval = setInterval(function() {
          count++;
          if (count > 1) { clearInterval(pulseInterval); return; }
          brandIcon.style.transform = 'scale(1.03)';
          setTimeout(function() { brandIcon.style.transform = ''; }, 300);
        }, 4000);
      });
      // Initial pulse after 2s
      setTimeout(function() {
        brandIcon.style.transform = 'scale(1.03)';
        setTimeout(function() { brandIcon.style.transform = ''; }, 300);
      }, 2000);
    }

  })();
  </script>
</body>
</html>
